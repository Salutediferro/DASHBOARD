// Salute di Ferro — database schema
// PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  DOCTOR
  COACH
  PATIENT
}

enum ProfessionalRole {
  DOCTOR
  COACH
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum MedicalReportCategory {
  BLOOD_TEST
  IMAGING
  CARDIOLOGY
  ENDOCRINOLOGY
  GENERAL_VISIT
  PRESCRIPTION
  VACCINATION
  SURGERY
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum CareRelationshipStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AppointmentType {
  IN_PERSON
  VIDEO_CALL
  VISIT
  FOLLOW_UP
  COACHING_SESSION
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum AiContext {
  GENERAL
  HEALTH_DATA
  REPORT_EXPLANATION
}

enum NotificationType {
  REMINDER
  CHECK_IN
  PAYMENT
  SYSTEM
  AI
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ============================================================
// ORGANIZATION (multi-brand / white-label)
// ============================================================

model Organization {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String   @unique
  logo           String?
  primaryColor   String?
  secondaryColor String?
  settings       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users         User[]
  subscriptions Subscription[]

  @@index([slug])
}

// ============================================================
// USER
// ============================================================

model User {
  id                  String              @id @default(uuid()) @db.Uuid
  email               String              @unique
  fullName            String
  firstName           String?
  lastName            String?
  sex                 Sex?
  birthDate           DateTime?           @db.Date
  heightCm            Float?
  avatarUrl           String?
  phone               String?
  taxCode             String?             @unique
  emergencyContact    String?
  role                UserRole            @default(PATIENT)
  organizationId      String              @db.Uuid
  stripeCustomerId    String?             @unique
  subscriptionStatus  SubscriptionStatus?
  onboardingCompleted Boolean             @default(false)

  // Clinical profile (free-text, PII — visible to authorized professionals)
  medicalConditions String?
  allergies         String?
  medications       String?
  injuries          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Professional ↔ Patient
  professionalRelations CareRelationship[] @relation("ProfessionalRelations")
  patientRelations      CareRelationship[] @relation("PatientRelations")

  // Clinical data owned by patient
  biometricLogs              BiometricLog[]
  checkInsAsPatient          CheckIn[]          @relation("PatientCheckIns")
  checkInsAsProfessional     CheckIn[]          @relation("ProfessionalCheckIns")
  appointmentsAsProfessional Appointment[]      @relation("ProfessionalAppointments")
  appointmentsAsPatient      Appointment[]      @relation("PatientAppointments")
  availabilitySlots          AvailabilitySlot[]

  medicalReportsAsPatient  MedicalReport[]    @relation("PatientMedicalReports")
  medicalReportsAsUploader MedicalReport[]    @relation("UploaderMedicalReports")
  reportPermissions        ReportPermission[] @relation("GranteePermissions")

  subscriptions   Subscription[]
  aiConversations AiConversation[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  // Patient onboarding via professional invite link
  professionalInvitations Invitation[] @relation("ProfessionalInvitations")
  usedInvitations         Invitation[] @relation("UsedInvitations")

  // Soft-delete marker used by GDPR delete (/api/me DELETE). The row is
  // kept until a cleanup job hard-deletes it, so audit trails survive.
  deletedAt DateTime?

  @@index([organizationId])
  @@index([role])
  @@index([email])
}

// ============================================================
// CARE RELATIONSHIP (professional ↔ patient pivot)
// ============================================================

model CareRelationship {
  id               String                 @id @default(uuid()) @db.Uuid
  professionalId   String                 @db.Uuid
  patientId        String                 @db.Uuid
  professionalRole ProfessionalRole
  status           CareRelationshipStatus @default(ACTIVE)
  startDate        DateTime               @default(now())
  endDate          DateTime?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  professional User @relation("ProfessionalRelations", fields: [professionalId], references: [id], onDelete: Cascade)
  patient      User @relation("PatientRelations", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([professionalId, patientId, professionalRole])
  @@index([professionalId])
  @@index([patientId])
  @@index([status])
}

// ============================================================
// BIOMETRICS & CHECK-INS
// ============================================================

model BiometricLog {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  date      DateTime @default(now())

  // Body composition
  weight            Float? // kg
  bmi               Float? // server-computed from weight + User.heightCm
  bodyFatPercentage Float? // %
  muscleMassKg      Float?
  bodyWaterPct      Float? // %

  // Circumferences (cm)
  waistCm  Float?
  hipsCm   Float?
  chestCm  Float?
  armsCm   Float?
  thighCm  Float?
  calvesCm Float?

  // Cardiovascular
  systolicBP  Int?
  diastolicBP Int?
  restingHR   Int? // bpm
  spo2        Float? // %
  hrv         Float? // ms

  // Metabolic
  glucoseFasting  Float? // mg/dL
  glucosePostMeal Float? // mg/dL
  ketones         Float? // mmol/L
  bodyTempC       Float?
  /// @deprecated legacy — use glucoseFasting / glucosePostMeal
  bloodGlucose    Float?

  // Sleep
  sleepHours      Float?
  sleepQuality    Int? // 1-10
  sleepBedtime    DateTime?
  sleepWakeTime   DateTime?
  sleepAwakenings Int?

  // Activity
  steps          Int?
  caloriesBurned Int?
  activeMinutes  Int?
  distanceKm     Float?

  energyLevel Int? // 1-10
  notes       String?

  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([date])
  @@index([patientId, date])
}

model CheckIn {
  id                    String           @id @default(uuid()) @db.Uuid
  patientId             String           @db.Uuid
  professionalId        String           @db.Uuid
  professionalRole      ProfessionalRole
  date                  DateTime         @default(now())
  weight                Float?
  measurements          Json? // { waist, chest, arms, ... }
  frontPhotoUrl         String?
  sidePhotoUrl          String?
  backPhotoUrl          String?
  notes                 String?
  professionalFeedback  String?
  aiAnalysis            String?
  createdAt             DateTime         @default(now())

  patient      User @relation("PatientCheckIns", fields: [patientId], references: [id], onDelete: Cascade)
  professional User @relation("ProfessionalCheckIns", fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([professionalId])
  @@index([date])
}

// ============================================================
// APPOINTMENTS
// ============================================================

model Appointment {
  id               String            @id @default(uuid()) @db.Uuid
  professionalId   String            @db.Uuid
  patientId        String            @db.Uuid
  professionalRole ProfessionalRole
  startTime        DateTime
  endTime          DateTime
  type             AppointmentType   @default(VIDEO_CALL)
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  meetingUrl       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  professional User @relation("ProfessionalAppointments", fields: [professionalId], references: [id], onDelete: Cascade)
  patient      User @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([patientId])
  @@index([startTime])
}

// ============================================================
// AVAILABILITY SLOTS (professional schedule)
// ============================================================

/// Either dayOfWeek (recurring) or date (one-off), never both.
/// XOR invariant enforced at the validator/service layer.
model AvailabilitySlot {
  id             String    @id @default(uuid()) @db.Uuid
  professionalId String    @db.Uuid
  /// Recurring slot: weekday 0 (Sunday) - 6 (Saturday). Mutually exclusive with `date`.
  dayOfWeek      Int?
  /// One-off slot: specific calendar date. Mutually exclusive with `dayOfWeek`.
  date           DateTime? @db.Date
  startTime      DateTime  @db.Time
  endTime        DateTime  @db.Time
  isRecurring    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  professional User @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([professionalId, dayOfWeek])
  @@index([professionalId, date])
}

// ============================================================
// SUBSCRIPTIONS (Stripe)
// ============================================================

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @db.Uuid
  organizationId       String             @db.Uuid
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

// ============================================================
// AI & NOTIFICATIONS
// ============================================================

model AiConversation {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  context   AiContext @default(GENERAL)
  messages  Json // [{ role, content, createdAt }]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([context])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  title     String
  body      String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================================
// MEDICAL REPORTS (GDPR Art. 9 — granular per-user permissions)
// ============================================================

model MedicalReport {
  id           String                @id @default(uuid()) @db.Uuid
  patientId    String                @db.Uuid
  uploadedById String                @db.Uuid
  fileUrl      String
  fileName     String
  mimeType     String
  fileSize     Int?
  category     MedicalReportCategory @default(OTHER)
  title        String
  notes        String?
  issuedAt     DateTime?             @db.Date
  uploadedAt   DateTime              @default(now())

  patient     User               @relation("PatientMedicalReports", fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy  User               @relation("UploaderMedicalReports", fields: [uploadedById], references: [id], onDelete: Restrict)
  permissions ReportPermission[]

  @@index([patientId])
  @@index([patientId, uploadedAt])
  @@index([category])
}

model ReportPermission {
  id        String    @id @default(uuid()) @db.Uuid
  reportId  String    @db.Uuid
  granteeId String    @db.Uuid
  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  revokedAt DateTime?

  report  MedicalReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  grantee User          @relation("GranteePermissions", fields: [granteeId], references: [id], onDelete: Cascade)

  @@unique([reportId, granteeId])
  @@index([granteeId])
  @@index([reportId])
}

// ============================================================
// PATIENT INVITATIONS (professional → patient onboarding link)
// ============================================================

/// A DOCTOR or COACH creates an Invitation to onboard a new patient.
/// The patient follows the URL (/register?invite=<token>) to sign up;
/// consuming the invite auto-creates a CareRelationship between the
/// inviting professional and the new patient. Tokens are one-shot and
/// expire after the `expiresAt` cutoff.
model Invitation {
  id               String           @id @default(uuid()) @db.Uuid
  token            String           @unique
  professionalId   String           @db.Uuid
  professionalRole ProfessionalRole
  email            String?
  firstName        String?
  lastName         String?
  note             String?
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime
  createdAt        DateTime         @default(now())
  usedAt           DateTime?
  usedByUserId     String?          @db.Uuid

  professional User  @relation("ProfessionalInvitations", fields: [professionalId], references: [id], onDelete: Cascade)
  usedBy       User? @relation("UsedInvitations", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([professionalId])
  @@index([status])
  @@index([expiresAt])
}

// ============================================================
// AUDIT LOG (GDPR Art. 30 — record of processing activities)
// ============================================================

/// Tamper-evident trail of sensitive actions. The row is kept even after
/// the actor is soft-deleted, so `actor` is nullable with `onDelete:
/// SetNull`. Populated via `logAudit()` in src/lib/audit.ts; callers
/// should pass the IP / user-agent extracted from the request headers.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
